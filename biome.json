{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"files": {
		"ignore": [
			"node_modules",
			".bun-cache",
			"dist",
			"packages/*/dist",
			"packages/*/.next/**",
			"packages/web/.next",
			".devos",
			"bun.lock"
		]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true
	},
	"organizeImports": {
		"enabled": true
	}
}
